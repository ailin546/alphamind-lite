# ============================================
# AlphaMind Lite - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================

# Application Environment: development | production | test
NODE_ENV=production

# Server Configuration
PORT=3000
HOST=0.0.0.0
TRUST_PROXY=true

# ---- API Configuration ----
# Binance API (public endpoints, no key required)
BINANCE_API_URL=https://api.binance.com
BINANCE_FUTURES_URL=https://fapi.binance.com
API_TIMEOUT=10000
API_RETRIES=3

# Fear & Greed Index
FEAR_GREED_URL=https://api.alternative.me/fng/

# Tavily News API (optional - get key at tavily.com)
TAVILY_API_KEY=

# ---- Logging ----
LOG_LEVEL=info
LOG_FORMAT=json
LOG_DIR=./logs
LOG_MAX_FILES=30
LOG_MAX_SIZE=50m

# ---- Health Check ----
HEALTH_CHECK_INTERVAL=30000
HEALTH_CHECK_TIMEOUT=5000

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=100

# ---- Notifications (optional) ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Watchlist ----
WATCHLIST=BTC,ETH,BNB,SOL,XRP,ADA,DOGE,AVAX
